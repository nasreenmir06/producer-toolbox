{
  "manifest_version": 3,
  "name": "Producer Toolbox",
  "version": "1.0.0",
  "permissions": [
    "sidePanel",
    "storage",
    "audioCapture",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open Producer Toolbox"
  },
  "icons": {
  "16": "icons/icon16.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
  }
}